# ==========================================================
# Unity .gitignore (schoolday)
# Unity가 자동 생성하는 파일은 커밋하지 않는다.
# 사람이 만든 것: Assets/, Packages/, ProjectSettings/ 만 추적.
# ==========================================================

# Unity 생성 폴더
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/
/[Mm]emoryCaptures/
/[Rr]ecordings/

# Asset meta 데이터는 대응 에셋이 무시될 때만 무시
!/[Aa]ssets/**/*.meta

# 자동 생성되는 VS/Rider/MonoDevelop 프로젝트 파일
.vs/
.vscode/
.idea/
ExportedObj/
.consulo/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity3D 생성 파일
sysinfo.txt
*.stackdump

# 빌드 산출물
*.apk
*.aab
*.unitypackage
*.app

# 크래시 리포트
crashlytics-build.properties

# OS 파일
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
